# URL base de la aplicación (opcional en Vercel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js (NextAuth v5)
AUTH_SECRET="generate-with-openssl-rand-base64-33"
AUTH_TRUST_HOST=true

# Google OAuth2
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://user:password@host:port/database"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://user:password@host:port/database"

# Admin Initialization
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="your-strong-admin-password"

# payments methods
MERCADOPAGO_ACCESS_TOKEN="your-mercadopago-access-token"
MERCADOPAGO_WEBHOOK_SECRET="your-mercadopago-webhook-secret"

NODE_ENV="development"

# caching
REDIS_URL="redis://localhost:6379"
CACHE_ENABLED=true

# Ollama (servidor local de modelos)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_EMBEDDING_MODEL="qwen3-embedding:8b"
OLLAMA_TIMEOUT=15000

# Búsqueda semántica (pgvector)
EMBEDDING_DIMENSIONS=4096
EMBEDDING_BATCH_SIZE=10
AI_FEATURE_SEMANTIC_SEARCH=true

# WhatsApp Cloud API (Meta)
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WHATSAPP_API_KEY="your-whatsapp-permanent-access-token"
WHATSAPP_WEBHOOK_SECRET="your-whatsapp-webhook-secret"
WHATSAPP_API_VERSION="v22.0"
WHATSAPP_VERIFY_TOKEN="your-custom-verify-token"