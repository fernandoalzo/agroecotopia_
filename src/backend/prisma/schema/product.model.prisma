model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  price       Int
  categoria   String
  unidad      String
  tag         String
  emoji       String
  images      String[]
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
