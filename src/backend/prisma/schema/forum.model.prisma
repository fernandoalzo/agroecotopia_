model ForumPost {
  id          String        @id @default(cuid())
  title       String
  body        String
  labels      String[]
  ratingTotal Int           @default(0)
  ratingCount Int           @default(0)
  isTrending  Boolean       @default(false)
  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  answers     ForumAnswer[]
  ratings     ForumRating[]
  embedding   ForumPostEmbedding?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([createdAt])
  @@index([ratingTotal, createdAt])
  @@index([authorId])
  @@index([labels], type: Gin)
}

model ForumAnswer {
  id          String        @id @default(cuid())
  content     String
  isAccepted  Boolean       @default(false)
  ratingTotal Int           @default(0)
  ratingCount Int           @default(0)
  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId      String
  post        ForumPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      ForumAnswer?  @relation("AnswerReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     ForumAnswer[] @relation("AnswerReplies")
  ratings     ForumRating[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ForumRating {
  id        String       @id @default(cuid())
  value     Int
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      ForumPost?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  answerId  String?
  answer    ForumAnswer? @relation(fields: [answerId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, postId])
  @@unique([userId, answerId])
}
