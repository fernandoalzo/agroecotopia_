enum Role {
  admin
  user
  seller
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String                  @unique
  emailVerified           DateTime?
  image                   String?
  password                String?
  role                    Role                    @default(user)
  accounts                Account[]
  pedidos                 Pedido[]
  conversationsAsUser     Conversation[]          @relation("ConversationUser")
  conversationsAsSeller   Conversation[]          @relation("ConversationSeller")
  e2eeDevice              E2EEDevice?
  forumPosts              ForumPost[]
  forumAnswers            ForumAnswer[]
  forumRatings            ForumRating[]
  stores                  Store[]
  storeRequests           StoreRequest[]
  // ─── Notification System Relations ───
  domainEvents            DomainEvent[]           @relation("DomainEventActor")
  createdNotifications    Notification[]          @relation("NotificationCreator")
  notificationRecipients  NotificationRecipient[]
  createdGroups           Group[]                 @relation("GroupCreator")
  groupMemberships        GroupMember[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  unreadNotificationCount Int                     @default(0)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}
