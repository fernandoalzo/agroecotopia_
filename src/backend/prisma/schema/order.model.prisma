enum PedidoEstado {
  PENDIENTE
  CONFIRMADO
  EN_PREPARACION
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

model Pedido {
  id                    String         @id @default(cuid())
  usuarioId             String
  accountId             String?        // Se deja como string opcional por ahora siguiendo la estructura de la base
  estado                PedidoEstado   @default(PENDIENTE)
  motivoCancelacion     String?        @db.Text
  direccionEntrega      String         @db.Text
  fechaPedido           DateTime       @default(now())
  fechaEntregaEstimada  DateTime?
  fechaEntregaReal      DateTime?
  subtotal              Decimal        @db.Decimal(12, 2)
  impuestos             Decimal        @db.Decimal(12, 2)
  costoEnvio            Decimal        @db.Decimal(12, 2)
  total                 Decimal        @db.Decimal(12, 2)
  notasCliente          String?        @db.Text
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  // Relaciones
  usuario               User           @relation(fields: [usuarioId], references: [id])
  detalles              DetallePedido[]

  @@index([usuarioId])
  @@index([estado])
  @@index([fechaPedido])
}

model DetallePedido {
  id             String   @id @default(cuid())
  pedidoId       String
  productoId     String
  cantidad       Decimal  @db.Decimal(12, 2)
  unidadMedida   String
  precioUnitario Decimal  @db.Decimal(12, 2)
  subtotal       Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relaciones
  pedido         Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto       Product  @relation(fields: [productoId], references: [id])

  @@index([pedidoId])
  @@index([productoId])
}
